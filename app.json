{
  "expo": {
    "name": "Nazar Kebab",
    "slug": "nazar-kebab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#040404"
    },
    "notification": {
      "icon": "./assets/images/logo.png",
      "color": "#FFD700"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nazar.kebab",
      "buildNumber": "6",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1085281959109-qdk6fkhs2jfr8rplfmnnhj9v6hvtcgj8"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#040404"
      },
      "package": "com.nazar.kebab"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://nazarkebab.vercel.app/"
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-apple-authentication"
    ],
    "scheme": "nazar-kebab",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "db083957-66af-4c0e-beb9-9cb50d8e0a5d"
      }
    },
    "owner": "mars21144s-organization",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/db083957-66af-4c0e-beb9-9cb50d8e0a5d",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    }
  }
}
